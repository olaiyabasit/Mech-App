# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=winki_project.settings.production

# Base URL for QR codes (set to your Railway public domain)
BASE_URL=https://your-app.up.railway.app

# PostgreSQL (Railway auto-injects these when you add a Postgres plugin)
POSTGRES_DATABASE=railway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=your-db-host.railway.internal
POSTGRES_PORT=5432
